CORS_ORIGINS=http://localhost:5173,https://bot-frontend-sooty.vercel.app
DEFAULT_INTERVAL=1h
DEFAULT_PERIOD=5d
CACHE_TTL_SECONDS=120
BOT_POLL_SECONDS=300
ENABLE_NEWS_ANALYSIS=true
NEWS_CACHE_TTL_SECONDS=900
NEWS_LOOKBACK_HOURS=24
FILTER_CLOSED_MARKETS=true
ENABLE_LEARNING=true
ENABLE_SESSION_SUGGESTIONS=true
SESSION_TIMEZONE=Africa/Nairobi
ASIA_SESSION_OPEN=03:00
ASIA_SESSION_CLOSE=11:00
LONDON_SESSION_OPEN=10:00
LONDON_SESSION_CLOSE=19:00
NEW_YORK_SESSION_OPEN=16:00
NEW_YORK_SESSION_CLOSE=00:00
LEARNING_HORIZON_HOURS=24
LEARNING_MIN_MOVE_PCT=0.0015
LEARNING_RATE=0.08
SESSION_ALIGNMENT_BOOST=0.4
SESSION_OFFSESSION_PENALTY=0.2
MODEL_STATE_PATH=data/model_state.json
